# bist-robogo — Environment Variables
# Copy this file to .env and fill in your own values.
# DO NOT commit the .env file to version control.

# ─── General ───
APP_NAME=bist-robogo
APP_ENV=development        # development | staging | production
DEBUG=true
SECRET_KEY=<generate-a-random-secret-key>

# ─── Backend ───
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/v1

# ─── PostgreSQL ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bist_robogo
POSTGRES_USER=bist_user
POSTGRES_PASSWORD=<your-postgres-password>
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── TimescaleDB ───
# TimescaleDB uses the same connection as PostgreSQL (runs as an extension)

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ─── Kafka / Redpanda ───
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Celery ───
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# ─── JWT ───
JWT_SECRET_KEY=<generate-a-random-jwt-secret-min-32-chars>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Broker API ───
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_API_URL=
BROKER_PAPER_TRADING=true

# ─── Data Sources ───
YAHOO_FINANCE_ENABLED=true

# ─── Email (SMTP) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@bist-robogo.com

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sentry (Error Tracking) ───
SENTRY_DSN=

# ─── OpenRouter AI ───
OPENROUTER_API_KEY=

# ─── CollectAPI (Real-time BIST Data) ───
COLLECTAPI_KEY=

# ─── MinIO (Object Storage) ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>
MINIO_BUCKET=bist-robogo

# ─── MLflow (Model Tracking) ───
MLFLOW_TRACKING_URI=http://localhost:5000
